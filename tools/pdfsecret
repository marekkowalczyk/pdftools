#!/usr/bin/env bash

# Loop through each provided PDF file
for file in "$@"; do
  # Check if the file argument is empty
  if [[ -z "$file" ]]; then
    continue
  fi
  
  # Print the file being processed
  printf "Processing file: $file\n"

  # Use the cpdf utility to add the text at the top of each page
  tmp=$(mktemp "$(dirname "$file")/.pdfsecret.XXXXXX")
  if cpdf "$file" \
      -add-text "Tajemnica przedsiebiorstwa" -top 16 -font "Helvetica" -color "black" -opacity 0.3 \
      -o "$tmp"; then
      mv "$tmp" "$file"
  else
      rm -f "$tmp"
      echo "Error: pdfsecret failed on '$file'" >&2
  fi
done